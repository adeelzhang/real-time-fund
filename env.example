# Supabase 配置
# 从 Supabase 项目设置中获取这些值：https://app.supabase.com/project/_/settings/api
# 复制此文件为 .env.local 并填入实际值；Docker 部署可复制为 .env

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 可选站长平台验证码。平台支持 DNS 验证时，优先使用 DNS。
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_BAIDU_SITE_VERIFICATION=
NEXT_PUBLIC_360_SITE_VERIFICATION=
NEXT_PUBLIC_SOGOU_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=

# 百度普通收录 API token。仅保存在服务端，不要添加 NEXT_PUBLIC_ 前缀。
BAIDU_SITE_TOKEN=
